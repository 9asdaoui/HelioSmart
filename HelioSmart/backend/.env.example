# Environment
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/heliosmart
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# External APIs
PVWATTS_API_KEY=iRJ5iHVeSt2HkcEzK8h2XCJ4FnpyvVGiFBMO3fjJ
OPENSOLAR_API_KEY=your-opensolar-api-key
OPENSOLAR_ORG_ID=your-opensolar-org-id

# Application
APP_NAME=HelioSmart
APP_VERSION=1.0.0
DEBUG=True

# Chatbot Configuration (Ollama)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
ENABLE_CHATBOT=true
ENABLE_RAG=true
ENABLE_SPEECH=true

# Storage Paths (optional - defaults set in code)
AUDIO_PATH=audio
VECTOR_DB_PATH=faiss_index
DOCUMENTS_DIR=documents
